# jarvis-revival environment template
# Copy to .env and fill with real values. Never commit .env.

# Anthropic (drafting via Sonnet, scoring via Haiku)
ANTHROPIC_API_KEY=

# Telegram bot used as the human-in-the-loop layer
# Bot token comes from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
# The single chat_id Jarvis sends to (Collin's personal chat with the bot)
TELEGRAM_CHAT_ID=

# Dripify (LinkedIn relationship automation)
# API key from Dripify settings
DRIPIFY_API_KEY=
# Webhook secret used to verify HMAC signatures on incoming Dripify events
DRIPIFY_WEBHOOK_SECRET=

# LinkedIn API (gated, used by handlers/linkedin_poster.py only when the trust
# gate opens - target ~30 days of stable manual-review drafts before flipping on)
LINKEDIN_OAUTH_CLIENT_ID=
LINKEDIN_OAUTH_CLIENT_SECRET=

# OpenLaws (case law and statutes corpus, upstream of Hallucination Shield and
# Caseread research)
OPENLAWS_API_KEY=
